# ── 基礎 ────────────────────────────────────────────────────────────
APP_NAME=xCloudVLMui Platform
DEBUG=false
SECRET_KEY=change-me-to-random-32-char-string!!

# ── 資料庫 ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./xcloudvlm.db

# ── ChromaDB ────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=maintenance_docs
EMBEDDING_TOP_K=5

# ── llama.cpp（Gemma 4 E4B） ─────────────────────────────────────────
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=gemma-4-e4b
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1
EMBED_MODEL=gemma-4-e4b

# ── live-vlm-webui ──────────────────────────────────────────────────
VLM_WEBUI_URL=http://localhost:8090

# ── CORS ────────────────────────────────────────────────────────────
# 以逗號分隔多個來源
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── NextAuth JWT Secret（與前端 NEXTAUTH_SECRET 一致）──────────────
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── MQTT Broker ──────────────────────────────────────────────────────
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_FILTER=xcloud/#
MQTT_ENABLED=true
